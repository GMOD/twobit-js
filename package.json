{
  "name": "@gmod/twobit",
  "version": "6.0.5",
  "description": "Read .2bit files in node or webpack",
  "license": "MIT",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/twobit-js.git"
  },
  "type": "module",
  "exports": {
    "import": "./esm/index.js",
    "require": "./dist/index.js"
  },
  "author": {
    "name": "Robert Buels",
    "email": "rbuels@gmail.com",
    "url": "https://github.com/rbuels"
  },
  "files": [
    "dist",
    "esm",
    "src"
  ],
  "scripts": {
    "test": "vitest",
    "clean": "rimraf dist esm",
    "format": "prettier --write .",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "prebuild": "pnpm clean",
    "build:esm": "tsc --outDir esm",
    "build:es5": "tsc --module commonjs --moduleResolution bundler --outDir dist",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "preversion": "pnpm lint && pnpm test --run && pnpm build",
    "postversion": "git push --follow-tags",
    "build": "pnpm build:esm && pnpm build:es5",
    "benchonly": "vitest bench",
    "bench": "./scripts/build-both-branches.sh \"$BRANCH1\" \"$BRANCH2\" && vitest bench",
    "coverage": "pnpm test --coverage",
    "docs": "documentation readme src/twoBitFile.ts --section=TwoBitFile",
    "postdocs": "pnpm format && git commit -am 'readme'",
    "version": "standard-changelog && git add CHANGELOG.md"
  },
  "keywords": [
    "bionode",
    "biojs"
  ],
  "dependencies": {
    "@jbrowse/quick-lru": "^7.3.5",
    "generic-filehandle2": "^2.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "documentation": "^14.0.3",
    "eslint": "^10.2.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "standard-changelog": "^7.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
