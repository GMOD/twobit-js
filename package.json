{
  "name": "@gmod/twobit",
  "version": "6.0.1",
  "description": "Read .2bit files in node or webpack",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "esm/index.js",
  "repository": "GMOD/twobit-js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "import": "./esm/index.js"
    },
    "require": {
      "require": "./dist/index.js"
    }
  },
  "author": {
    "name": "Robert Buels",
    "email": "rbuels@gmail.com",
    "url": "https://github.com/rbuels"
  },
  "engines": {
    "node": ">=6"
  },
  "files": [
    "dist",
    "esm",
    "src"
  ],
  "scripts": {
    "test": "vitest",
    "benchonly": "vitest bench",
    "bench": "./scripts/build-both-branches.sh \"$BRANCH1\" \"$BRANCH2\" && vitest bench",
    "format": "prettier --write .",
    "coverage": "yarn test --coverage",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "docs": "documentation readme src/twoBitFile.ts --section=TwoBitFile",
    "postdocs": "yarn format && git commit -am 'readme'",
    "clean": "rimraf dist esm",
    "prebuild": "yarn clean",
    "build:esm": "tsc --outDir esm",
    "build:es5": "tsc --module commonjs --outDir dist",
    "build": "yarn build:esm && yarn build:es5",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "preversion": "yarn docs && yarn build",
    "version": "standard-changelog && git add CHANGELOG.md",
    "postversion": "git push --follow-tags"
  },
  "keywords": [
    "bionode",
    "biojs"
  ],
  "dependencies": {
    "generic-filehandle2": "^2.0.18"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "documentation": "^14.0.1",
    "eslint": "^9.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "standard-changelog": "^7.0.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
